rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Logo uploads - users can upload to their own folder
    match /logos/{userId}/{fileName} {
      // Allow public read for logos - they appear in shared pitches and one-pagers
      // The signed download URL from getDownloadURL() also works, but direct public access
      // ensures logos render in all contexts (shared pitches, embedded content, PDFs)
      allow read: if true;

      // Only the owner can upload/delete their logos
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024  // Max 2MB
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Avatar uploads - users can upload their profile avatar
    match /avatars/{userId}/{fileName} {
      // Avatars can be read publicly (for display in shared content)
      allow read: if true;

      // Only the owner can upload/delete their avatar
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 6 * 1024 * 1024  // Max 6MB
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Sales library documents - owner read/write/delete
    match /salesLibrary/{userId}/{fileName} {
      // Only the owner can read their documents
      allow read: if request.auth != null && request.auth.uid == userId;

      // Only the owner can upload documents (max 25MB)
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 25 * 1024 * 1024;

      // Only the owner can delete their documents
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Pitch assets (if you add image uploads to pitches)
    match /pitches/{pitchId}/{fileName} {
      // Only authenticated users can read pitch assets
      // Public pitch sharing should use signed URLs or pitch-specific tokens
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;  // Max 5MB
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
