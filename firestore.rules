rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is an admin (email exists in admins collection)
    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Check if user is a super admin
    function isSuperAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'super_admin';
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    // Path: /users/{userId}
    // User profiles, settings, and preferences

    match /users/{userId} {
      // Users can only read/write their own document
      // Admins can read all users for admin panel
      // Workspace members can read their owner's user doc for plan inheritance
      allow read: if isOwner(userId) || isAdmin() ||
        (isAuthenticated() &&
         exists(/databases/$(database)/documents/teams/$(userId)) &&
         request.auth.uid in get(/databases/$(database)/documents/teams/$(userId)).data.memberUids);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }
    
    // ============================================
    // PITCHES COLLECTION
    // ============================================
    // Path: /pitches/{pitchId}

    match /pitches/{pitchId} {
      // READ: Owner can read their own pitches, Admins can read all pitches
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());

      // Public shared pitches (no auth required for viewing)
      allow read: if resource.data.shared == true ||
                    (resource.data.sharing != null && resource.data.sharing.public == true);

      // CREATE: Must be authenticated and set userId to their own
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // UPDATE: Owner can update OR anyone can update analytics fields only (for view tracking)
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['analytics']);

      // DELETE: Only owner can delete
      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // USAGE COLLECTION
    // ============================================
    // Path: /usage/{usageId}
    // Format: {userId}_{period} e.g., "user123_2026-01"
    
    match /usage/{usageId} {
      // Users can read their own usage
      allow read: if isAuthenticated() && 
                    usageId.matches(request.auth.uid + '_.*');
      
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }
    
    // ============================================
    // TEMPLATES COLLECTION
    // ============================================
    // Path: /templates/{templateId}
    
    match /templates/{templateId} {
      // Anyone authenticated can read public/system templates
      allow read: if isAuthenticated() && 
                    (resource.data.isPublic == true || 
                     resource.data.isSystem == true ||
                     resource.data.userId == request.auth.uid);
      
      // Users can create their own templates
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can update/delete their own templates (not system ones)
      allow update, delete: if isAuthenticated() && 
                              resource.data.userId == request.auth.uid &&
                              resource.data.isSystem != true;
    }
    
    // ============================================
    // PITCH ANALYTICS COLLECTION
    // ============================================
    // Path: /pitchAnalytics/{pitchId}
    
    match /pitchAnalytics/{pitchId} {
      // Open to any authenticated user — pitchAnalytics docs have no userId field
      // (written by public track-view endpoint via Admin SDK, never includes userId).
      // data is view/click counters only. Writes: authenticated users only (trackShare).
      // create,update only — delete not needed and not granted.
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();

      // Events subcollection
      match /events/{eventId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated();
      }

      // shareEvents subcollection — written by trackShare() in api.js
      match /shareEvents/{eventId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated();
      }
    }
    
    // ============================================
    // CONTACTS COLLECTION
    // ============================================
    // Path: /contacts/{userId}/contacts/{contactId}
    
    match /contacts/{userId}/contacts/{contactId} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // SEQUENCES COLLECTION
    // ============================================
    // Path: /sequences/{userId}/sequences/{sequenceId}
    
    match /sequences/{userId}/sequences/{sequenceId} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // PRD COLLECTION (Read Only)
    // ============================================
    // Path: /prd/{document}
    
    match /prd/{document} {
      allow read: if isAuthenticated();
      allow write: if false;  // Admin only via console
    }
    
    // ============================================
    // SETTINGS COLLECTION
    // ============================================
    // Path: /settings/{document}
    
    match /settings/{document} {
      allow read: if isAuthenticated();
      allow write: if false;  // Admin only
    }
    
    // ============================================
    // WORKSPACES COLLECTION
    // ============================================
    // Path: /workspaces/{workspaceId}

    match /workspaces/{workspaceId} {
      // Only workspace owner or members can read
      allow read: if isAuthenticated() &&
                    (resource.data.ownerId == request.auth.uid ||
                     request.auth.uid in resource.data.memberIds);

      // Only authenticated users can create (must set themselves as owner)
      allow create: if isAuthenticated() &&
                      request.resource.data.ownerId == request.auth.uid;

      // Only owner can update/delete
      allow update, delete: if isAuthenticated() &&
                              resource.data.ownerId == request.auth.uid;
    }

    // ============================================
    // PITCH VERSIONS COLLECTION
    // ============================================
    // Path: /pitchVersions/{versionId}
    // Read-only from client; all writes via Cloud Functions (Admin SDK)

    match /pitchVersions/{versionId} {
      // Users can read versions for their own pitches
      allow read: if isAuthenticated();

      // Only Cloud Functions can write versions (via Admin SDK)
      allow write: if false;
    }

    // ============================================
    // MARKET REPORTS COLLECTION
    // ============================================
    // Path: /marketReports/{reportId}

    match /marketReports/{reportId} {
      // Users can only read their own reports
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Users can create reports with their userId
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Users can delete their own reports
      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    // ============================================
    // ONE-PAGERS COLLECTION
    // ============================================
    // Path: /onepagers/{onepagerId}

    match /onepagers/{onepagerId} {
      // Public read only if explicitly shared (shareId present); otherwise owner-only
      allow read: if resource.data.shareId != null
                  || (request.auth != null && resource.data.userId == request.auth.uid);

      // Users can create one-pagers with their userId
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Users can update/delete their own one-pagers
      // Also allow anyone to update analytics fields only
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['analytics']);

      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    // ============================================
    // ICPS COLLECTION
    // ============================================
    // Path: /icps/{icpId}

    match /icps/{icpId} {
      // Users can read their own ICPs, admins can read all
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());

      // Users can create ICPs with their userId
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Users can update/delete their own ICPs
      allow update, delete: if isAuthenticated() &&
                              resource.data.userId == request.auth.uid;
    }

    // ============================================
    // ADMIN COLLECTIONS
    // ============================================

    // Admins collection - only super_admins can manage
    match /admins/{email} {
      // Admins can read their own record to check access
      allow read: if isAuthenticated() &&
                    request.auth.token.email == email;
      // Super admins can read all and manage admins
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // Platform config - public read, admin write
    match /platformConfig/{docId} {
      allow read: if true;  // Public read for pricing
      allow write: if isAdmin();
    }

    // Discount codes - admins only
    match /discountCodes/{codeId} {
      allow read, write: if isAdmin();
    }

    // Code redemptions - admins can read, users can create (redeem)
    match /codeRedemptions/{redemptionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ============================================
    // SALES LIBRARY COLLECTIONS
    // ============================================

    // Sales documents - owner read only (writes via Admin SDK from Cloud Functions)
    match /salesDocuments/{docId} {
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Customer library config - owner read only (writes via Admin SDK)
    match /customerLibraryConfig/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // ============================================
    // PITCH TEMPLATES COLLECTION
    // ============================================
    // Path: /pitchTemplates/{templateId}
    // System and user-created one-pager templates.
    // Written via Admin SDK (seed script / admin console) only.

    match /pitchTemplates/{templateId} {
      // Any authenticated user can read templates (system defaults + their own)
      allow read: if isAuthenticated() &&
                    (resource.data.isSystemDefault == true ||
                     resource.data.createdBy == request.auth.uid);

      // Only Cloud Functions (Admin SDK) can write templates
      allow write: if false;
    }

    // ============================================
    // MARKET BENCHMARKS COLLECTION
    // ============================================
    // Path: /marketBenchmarks/{benchmarkId}
    // Cross-product feed — written by Cloud Functions (Admin SDK),
    // read by PathManager and other PathSynch products

    match /marketBenchmarks/{benchmarkId} {
      // Public read — PathManager reads without SynchIntro auth
      allow read: if true;
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // ============================================
    // WEBSITE VISITORS COLLECTION
    // ============================================
    // Path: /websiteVisitors/{visitorId}
    // Visitor Intel — IP-to-company resolution events per user

    match /websiteVisitors/{visitorId} {
      // Only the owning user can read/write their visitor records
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid;

      // Session subcollection — Cloud Functions only
      match /sessions/{sessionId} {
        allow read: if isAuthenticated() && request.auth.uid == visitorId;
        allow write: if false; // Cloud Functions via Admin SDK
      }
    }

    // ============================================
    // VISITOR INTEL SUMMARY COLLECTION
    // ============================================
    // Path: /visitorIntelSummary/{merchantId}/accounts/{accountKey}
    // Account-level scoring aggregation. Written by Cloud Functions.

    match /visitorIntelSummary/{merchantId} {
      allow read: if isAuthenticated() && request.auth.uid == merchantId;
      allow write: if false; // Cloud Functions via Admin SDK

      match /accounts/{accountKey} {
        allow read: if isAuthenticated() && request.auth.uid == merchantId;
        allow write: if false; // Cloud Functions via Admin SDK
      }
    }

    // ============================================
    // MERCHANT CONFIG COLLECTION
    // ============================================
    // Path: /merchantConfig/{merchantId}
    // Visitor Intel — URL mappings, thresholds, learning mode settings
    // Doc ID = userId. Read/write via Cloud Functions (Admin SDK).
    // Client reads own config; writes go through API endpoints.

    match /merchantConfig/{merchantId} {
      allow read: if isAuthenticated() && request.auth.uid == merchantId;
      allow write: if false; // Cloud Functions only via Admin SDK
    }

    // ============================================
    // IP CACHE COLLECTION
    // ============================================
    // Path: /ipCache/{cacheId}
    // Cached IP-to-company lookups, scoped per user

    match /ipCache/{cacheId} {
      // Only the owning user can read/write their cached IP records
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid;
    }

    // ============================================
    // INTENT SIGNALS CACHE COLLECTION
    // ============================================
    // Path: /intentSignalsCache/{docId}
    // Shared cache per vertical+market — that's the moat.
    // Written by Cloud Functions (Admin SDK). Client reads only.

    match /intentSignalsCache/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================
    // CATEGORY VELOCITY SNAPSHOTS COLLECTION
    // ============================================
    // Path: /categoryVelocitySnapshots/{docId}
    // Append-only velocity trend history. Written by Cloud Functions only.

    match /categoryVelocitySnapshots/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================
    // KEYWORDS EVERYWHERE CREDIT LOG COLLECTION
    // ============================================
    // Path: /ke_credit_log/{docId}
    // Admin visibility into KE API usage per merchant.

    match /ke_credit_log/{docId} {
      allow read: if isAuthenticated() &&
                    resource.data.merchantId == request.auth.uid;
      allow write: if false;
    }

    match /userActivityLog/{docId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================
    // PROSPECT INTEL COLLECTIONS
    // ============================================
    // Path: /prospectIntel/{batchId}
    //       /prospectIntel/{batchId}/prospects/{prospectId}
    //
    // Batch docs are created by Cloud Functions (Admin SDK).
    // Client reads batch docs (onSnapshot progress listener) and
    // writes workflowStatus updates to individual prospect docs.

    match /prospectIntel/{batchId} {
      // Owner can read (real-time batch progress listener + table view)
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Cloud Functions create/update via Admin SDK — no client write needed
      allow create, update, delete: if false;

      match /prospects/{prospectId} {
        // Owner can read and update prospect workflow status.
        // Ownership is verified by checking the parent batch doc.
        allow read: if isAuthenticated() &&
                      get(/databases/$(database)/documents/prospectIntel/$(batchId)).data.userId
                        == request.auth.uid;

        // Client writes workflowStatus, disqualified, workflowUpdatedAt only
        allow update: if isAuthenticated() &&
                        get(/databases/$(database)/documents/prospectIntel/$(batchId)).data.userId
                          == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['workflowStatus', 'disqualified', 'workflowUpdatedAt']);

        // Cloud Functions create prospects and write enriched data via Admin SDK
        allow create, delete: if false;
      }
    }

    // ============================================
    // ICP PROFILES COLLECTION
    // ============================================
    // Path: /icpProfiles/{profileId}
    //
    // Default profiles (isDefault: true) are seeded client-side on first load
    // via a batch.set with merge:true — any authenticated user may seed them.
    // User-created profiles (userId field) are owner-only for writes.

    match /icpProfiles/{profileId} {
      // Any authenticated user can read (needed to populate ICP selector dropdown)
      allow read: if isAuthenticated();

      // Seed default profiles (isDefault: true, no userId) or create own custom profiles
      allow create: if isAuthenticated() &&
                      (request.resource.data.isDefault == true ||
                       request.resource.data.userId == request.auth.uid);

      // Update default profiles (idempotent seed re-runs) or own custom profiles
      allow update: if isAuthenticated() &&
                      (resource.data.isDefault == true ||
                       resource.data.userId == request.auth.uid);

      // No client-side deletes
      allow delete: if false;
    }

    // ============================================
    // CREDIT LEDGER COLLECTION
    // ============================================
    // Path: /creditLedger/{docId}
    //
    // Idempotency-keyed credit audit trail (format: {userId}_{batchId}).
    // Written exclusively by Cloud Functions via Admin SDK (bypasses rules).
    // Client reads own entries for credit balance / audit display.

    match /creditLedger/{docId} {
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      allow write: if false; // Cloud Functions only via Admin SDK
    }

    // ============================================
    // TEAMS COLLECTION
    // ============================================
    // Path: /teams/{ownerUid}
    // Doc ID = owner's UID. Members embedded as array.
    // All writes via Cloud Functions (Admin SDK).

    match /teams/{ownerUid} {
      // Owner can always read their own team doc (direct GET by ownerUid).
      // Members can read it too (needed for workspace plan inheritance).
      // Note: array-contains queries on memberUids do NOT satisfy the 'in' rule at
      // query-planning time — member team lookups must go through the backend API
      // (GET /team) which uses Admin SDK, bypassing rules.
      allow get:  if isAuthenticated() && (
        request.auth.uid == ownerUid ||
        request.auth.uid in resource.data.memberUids
      );
      allow list: if isAuthenticated() && request.auth.uid == ownerUid;
      // All mutations go through Cloud Functions (Admin SDK) — no direct client writes.
      allow write: if false;
    }

    // ============================================
    // TEAM INVITATIONS COLLECTION
    // ============================================
    // Path: /teamInvitations/{inviteId}
    // All writes via Cloud Functions (Admin SDK) only.

    match /teamInvitations/{inviteId} {
      allow read:   if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // OPPORTUNITY BRIEFS COLLECTION
    // ============================================
    // Path: /opportunityBriefs/{briefId}
    // Owner-scoped read/write. Public read via shareToken handled server-side
    // (Cloud Functions queries by shareToken, no client-side direct access needed).

    match /opportunityBriefs/{briefId} {
      // Owner-scoped read. Public share access is handled server-side (Cloud Functions
      // query by shareToken via Admin SDK — no client-side direct access needed).
      allow read:   if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // AGENCY BRAND OVERRIDES COLLECTION
    // ============================================
    // Path: /agencyBrandOverrides/{uid}
    // Doc ID = agency owner's UID. Stores user-configurable branding fields
    // (logoUrl, accentColor, companyName, etc.).
    // planTier and featureFlags are server-controlled — written by Admin SDK only.
    // Client writes are allowed ONLY when those protected fields are not touched.

    match /agencyBrandOverrides/{uid} {
      // Owner reads their own brand config
      allow read: if isOwner(uid);

      // Owner can create their own doc, but must not set planTier or featureFlags
      // (those fields are Admin SDK only — set via /brand/entitlements endpoint)
      allow create: if isOwner(uid) &&
                      !request.resource.data.keys().hasAny(['planTier', 'featureFlags']);

      // Owner can update their own doc, but cannot touch planTier or featureFlags
      allow update: if isOwner(uid) &&
                      !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['planTier', 'featureFlags']);

      // No client-side deletes — Admin SDK only
      allow delete: if false;
    }

    // ============================================
    // AGENCY ENTITLEMENTS COLLECTION
    // ============================================
    // Path: /agencyEntitlements/{uid}
    // Doc ID = agency owner's UID. Server-controlled entitlement flags:
    // planTier, canUseCustomLogo, canUseCustomColors, showPoweredByPathSynch.
    // Written exclusively by Cloud Functions (Admin SDK). Never client-writable.

    match /agencyEntitlements/{uid} {
      // Owner reads their own entitlements (brandResolver needs this)
      allow read: if isOwner(uid);

      // All writes via Cloud Functions (Admin SDK) only
      allow write: if false;
    }
  }
}
