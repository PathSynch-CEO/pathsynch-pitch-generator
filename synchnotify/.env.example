# ============================================
# SynchNotify Environment Variables
# ============================================
# Copy to .env and fill in values. NEVER commit .env to git.

# ---- Server ----
PORT=8080

# ---- Firestore ----
# Firestore project ID (pathsynch-pitch-creation for SynchIntro data)
FIRESTORE_PROJECT_ID=pathsynch-pitch-creation

# ---- HMAC Signing Keys ----
# Per-source signing keys for event authentication.
# Store in GCP Secret Manager for production.
# For local dev, set here (never commit real values).
SYNCHNOTIFY_HMAC_KEY_SYNCHINTRO=
SYNCHNOTIFY_HMAC_KEY_PATHMANAGER=

# ---- Cloud Tasks ----
# Full queue path: projects/{project}/locations/{location}/queues/{queue}
CLOUD_TASKS_QUEUE_PATH=

# ---- Service URL ----
# URL of this SynchNotify service (for Cloud Task callback)
SYNCHNOTIFY_SERVICE_URL=http://localhost:8080

# ---- Slack (S2) ----
# Slack bot token — MUST be in Secret Manager for production.
# For local dev only (never commit real values):
SLACK_BOT_TOKEN=

# ---- Secret Manager ----
# GCP project where secrets are stored
GCP_SECRET_PROJECT_ID=pathconnect-442522

# ---- Instantly Webhooks (S3) ----
# Per-merchant webhook secrets are stored in Firestore merchantConfig/{tenantId}.instantlyWebhookSecret
# No global env var needed — each merchant has their own secret.
# To generate a webhook secret for a merchant:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store the generated value in merchantConfig/{tenantId}.instantlyWebhookSecret

# ---- GCP ----
# For local dev with Application Default Credentials:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
