# SynchIntro Cloud Functions — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# Rules:
#   - GOOGLE_APPLICATION_CREDENTIALS must NEVER be set here in production.
#     Cloud Functions authenticate via the default service account automatically.
#     Local dev only: set in your shell — e.g., $env:GOOGLE_APPLICATION_CREDENTIALS="./key.json"
#   - THEORG_API_KEY lives in Secret Manager ONLY (not in .env).
#   - INSTANTLY_API_KEY and ATTIO_API_KEY go in .env ONLY (not in secrets[]).
#   - GCP_PROJECT is a reserved env var name — use PATHSYNCH_GCP_PROJECT instead.

# ============================================================
# CORE RUNTIME
# ============================================================
NODE_ENV=production
FRONTEND_URL=https://your-app.web.app
API_BASE_URL=https://us-central1-your-project.cloudfunctions.net/api

# ============================================================
# GOOGLE / GCP
# ============================================================
PATHSYNCH_GCP_PROJECT=your-gcp-project-id
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_CX=your_custom_search_engine_id
GOOGLE_PSI_API_KEY=your_pagespeed_insights_api_key
# GOOGLE_APPLICATION_CREDENTIALS — DO NOT set in .env. Local dev only (see above).

# ============================================================
# GEMINI / AI
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
PERPLEXITY_API_KEY=your_perplexity_api_key

# ============================================================
# FIREBASE / STRIPE
# ============================================================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ============================================================
# CRM / OUTREACH INTEGRATIONS
# ============================================================
ATTIO_API_KEY=your_attio_api_key
INSTANTLY_API_KEY=your_instantly_api_key
INSTANTLY_ENCRYPTION_KEY=your_64_char_hex_aes256_key

# ============================================================
# DATA ENRICHMENT APIs
# ============================================================
SERPER_API_KEY=your_serper_api_key
SERPAPI_KEY=your_serpapi_key
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password
KEYWORDS_EVERYWHERE_API_KEY=your_ke_api_key
IPINFO_TOKEN=your_ipinfo_token
CORESIGNAL_API_KEY=your_coresignal_api_key

# ============================================================
# PUBLIC DATA ENRICHMENT (all optional)
# ============================================================
CENSUS_API_KEY=your_census_api_key
FBI_CRIME_API_KEY=your_fbi_crime_api_key
ZYLA_API_KEY=your_zyla_api_key

# ============================================================
# SENDGRID
# ============================================================
SENDGRID_API_KEY=your_sendgrid_api_key

# ============================================================
# ANALYTICS
# ============================================================
HUMBLYTICS_SITE_TOKEN=your_humblytics_token
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_PROJECT_ID=your_posthog_project_id

# ============================================================
# PROSPECT INTEL / CLOUD TASKS
# ============================================================
PROSPECT_AGENT_URL=https://prospect-research-YOUR_PROJECT.us-central1.run.app
PROSPECT_TASK_HANDLER_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/processProspectTask
PROSPECT_TASK_SECRET=your_shared_task_secret

# ============================================================
# NEMOCLAW
# ============================================================
NEMOCLAW_SERVICE_KEY=your_nemoclaw_service_key

# ============================================================
# ENTITY360 / PATHMANAGER INTEGRATION
# ============================================================
ENTITY360_SERVICE_URL=https://entity360-YOUR_PROJECT.us-central1.run.app
ENTITY360_INTERNAL_API_KEY=your_entity360_internal_key
PATHMANAGER_JWT_SECRET=your_pathmanager_jwt_secret
PATHMANAGER_LOCAL_INTEL_KEY=your_pathmanager_local_intel_key

# ============================================================
# VERTEX AI / VECTOR SEARCH
# ============================================================
VERTEX_SEARCH_DATA_STORE_ID=your_vertex_search_data_store_id
VECTOR_SEARCH_API_ENDPOINT=your_vector_search_api_endpoint
VECTOR_SEARCH_INDEX_ENDPOINT_ID=your_index_endpoint_id
VECTOR_SEARCH_INDEX_ID=your_index_id
VECTOR_SEARCH_DEPLOYED_INDEX_ID=your_deployed_index_id

# ============================================================
# RAG / KNOWLEDGE BASE
# ============================================================
RAG_SERVICE_URL=https://your-rag-service.run.app

# ============================================================
# PATHCONNECT
# ============================================================
PATHCONNECT_URL=https://your-pathconnect-url.com
PM_GAUTH_CLIENT_ID=your_google_oauth_client_id
PM_GAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ============================================================
# AISYNCH (optional — set to true to enable)
# ============================================================
AISYNCH_ALLOW_TEST_TOKEN=false

# ============================================================
# FEATURE FLAGS (set to true to enable)
# ============================================================
ENABLE_MAP_PACK_ENRICHMENT=false
ENABLE_AD_SPEND_ENRICHMENT=false
ENABLE_WEBSITE_SIGNALS_ENRICHMENT=false
ENABLE_AI_VISIBILITY_ENRICHMENT=false
ENABLE_CRIME_DATA_ENRICHMENT=false
ENABLE_USASPENDING_ENRICHMENT=false
ENABLE_PROPUBLICA_NONPROFIT_ENRICHMENT=false
ENABLE_IRS_BMF_ENRICHMENT=false
ENABLE_CENSUS_GOVERNMENTS_ENRICHMENT=false
ENABLE_FAC_ENRICHMENT=false
ENABLE_GSA_CALC_ENRICHMENT=false
ENABLE_CORESIGNAL=false
ENABLE_COMPETITOR_VALIDATION_LOGGING=false
